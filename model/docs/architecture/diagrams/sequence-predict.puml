@startuml
title Sequence - POST /predict

actor Client
participant "FastAPI /predict\napps/api/api.py" as API
participant "get_model_bundle()\n@lru_cache" as Cache
participant "ml/artifacts/\nmodel_readiness.json + active joblib" as Artifact
participant "predict_proxy_valuation_from_bundle()" as Inference
participant "validate_inference_record()" as Validation
participant "prepare_inference_frame()" as Preprocessing
participant "bundle.model.predict(...)\nvia _predict_model_output()" as Model
participant "explain_prediction_from_bundle()" as Explainer

Client -> API: POST /predict\nSinglePredictionRequest JSON
activate API

API -> API: FastAPI + Pydantic validate request
API -> Cache: get_model_bundle()
activate Cache

alt First call, bundle not cached yet
  Cache -> Artifact: read active model manifest and joblib
  Artifact --> Cache: ready RUB model payload
else Bundle already cached
  Cache --> API: cached LoadedModelBundle
end

Cache --> API: LoadedModelBundle
deactivate Cache

API -> Inference: predict_proxy_valuation_from_bundle(\nobject_features, bundle, include_explanation)
activate Inference

Inference -> Validation: validate physical realism, categories, geo, region
Validation --> Inference: normalized features + confidence/warnings
Inference -> Preprocessing: prepare_inference_frame(object_features, feature_config)
activate Preprocessing
Preprocessing --> Inference: model-ready DataFrame
deactivate Preprocessing

Inference -> Model: predict(frame)
activate Model
Model --> Inference: expected_price_proxy
deactivate Model

opt include_explanation == true
  Inference -> Explainer: explain_prediction_from_bundle(...)
  activate Explainer
  Explainer --> Inference: top_factors + explanation_summary
  deactivate Explainer
end

Inference --> API: valuation payload
deactivate Inference

API -> API: _sanitize_for_json(...) + PredictionResponse(...)
API --> Client: 200 OK JSON
deactivate API
@enduml
