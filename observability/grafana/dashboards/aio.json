{
  "uid": "aio",
  "title": "AIO — Platform Overview",
  "description": "Единый дашборд: сервисы, трейсы, метрики, ключевые бизнес-показатели",
  "tags": ["ais", "overview", "traces"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "links": [
    { "title": "Golden Signals", "url": "/d/golden-signals", "type": "link", "icon": "external link" },
    { "title": "AIO Logging",    "url": "/d/aio-logging",    "type": "link", "icon": "external link" }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Сервис",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, job)",
        "multi": false,
        "includeAll": true,
        "allValue": ".+",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Service Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "title": "realestate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background" },
      "targets": [{ "expr": "up{job=\"realestate\"}", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "nlp-parser",
      "type": "stat",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background" },
      "targets": [{ "expr": "up{job=\"nlp-parser\"}", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "metrics",
      "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background" },
      "targets": [{ "expr": "up{job=\"metrics-svc\"}", "refId": "A" }]
    },
    {
      "id": 5,
      "title": "scheduler",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background" },
      "targets": [{ "expr": "up{job=\"scheduler\"}", "refId": "A" }]
    },
    {
      "id": 6,
      "title": "Model Loaded",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NO MODEL", "color": "red" } } }
          ],
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "name", "colorMode": "background" },
      "targets": [
        {
          "expr": "count_over_time({project=\"diploma\", service=\"realestate\"} |= \"model_loaded\" [$__range])",
          "legendFormat": "v2_russia2021",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active Users (session window)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 3 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "count(count_over_time({project=\"diploma\"} |~ \"user_id\" | json | user_id != \"\" [$__range]) by (user_id))",
          "legendFormat": "Users",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Throughput Overview",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Req/s per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by(job) (rate(http_requests_total{job=~\"$service\"}[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "P95 Latency per Service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$service\"}[1m])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Distributed Traces",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "title": "Service Graph (Tempo)",
      "type": "nodeGraph",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "serviceMap",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              { "id": "links", "value": [{ "title": "View trace", "url": "/explore?left=${__data.fields.traceID}&datasource=tempo" }] }
            ]
          }
        ]
      },
      "options": { "footer": { "show": false } },
      "targets": [
        {
          "queryType": "search",
          "refId": "A",
          "limit": 20
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Бизнес-метрики",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "title": "ML Predictions (model-runs)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate({project=\"diploma\", service=\"realestate\"} |~ \"model_run|predict|score\" [1m]))",
          "legendFormat": "ML events/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "title": "Auth Events",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate({project=\"diploma\"} |~ \"(?i)(login|logout|register|token)\" [1m]))",
          "legendFormat": "auth events/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "title": "Parse Events (NLP)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate({project=\"diploma\", service=\"nlp-parser\"} [1m]))",
          "legendFormat": "nlp events/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Error Log Stream",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 }
    },
    {
      "id": 41,
      "title": "Ошибки (ERROR level)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{project=\"diploma\", level=\"error\"}",
          "legendFormat": "",
          "refId": "A",
          "maxLines": 100
        }
      ]
    }
  ]
}
