{
  "uid": "golden-signals",
  "title": "Golden Signals",
  "description": "Rate · Errors · Latency · Saturation — все сервисы АИС",
  "tags": ["ais", "golden-signals"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Сервис",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, job)",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "interval",
        "label": "Интервал",
        "type": "interval",
        "options": [
          { "text": "30s", "value": "30s" },
          { "text": "1m",  "value": "1m",  "selected": true },
          { "text": "5m",  "value": "5m" },
          { "text": "10m", "value": "10m" }
        ],
        "current": { "text": "1m", "value": "1m" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Throughput & Errors",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by(job) (rate(http_requests_total{job=~\"$service\"}[$interval]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (5xx req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by(job) (rate(http_requests_total{job=~\"$service\", status_code=~\"5..\"}[$interval]))",
          "legendFormat": "{{job}} 5xx",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error % per service",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "100 * sum by(job) (rate(http_requests_total{job=~\"$service\",status_code=~\"5..\"}[$interval])) / sum by(job) (rate(http_requests_total{job=~\"$service\"}[$interval]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "x": 8, "y": 9, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "expr": "sum by(job) (http_requests_in_progress{job=~\"$service\"})",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Requests (window)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto" },
      "targets": [
        {
          "expr": "sum by(job) (increase(http_requests_total{job=~\"$service\"}[$__range]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Latency",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$interval])))",
          "legendFormat": "p50 {{job}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$interval])))",
          "legendFormat": "p95 {{job}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$interval])))",
          "legendFormat": "p99 {{job}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "Latency P95 now",
      "type": "bargauge",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 2.0 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$interval])))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Saturation — Containers",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "CPU Usage per Container (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by(service) (rate(container_cpu_usage_seconds_total{service!=\"\"}[$interval])) * 100",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Memory Usage per Container (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{service!=\"\"} / 1024 / 1024",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "Host CPU",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$interval])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 24,
      "title": "Host Memory",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "RAM %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 25,
      "title": "Host Disk I/O",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[$interval])",
          "legendFormat": "read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[$interval])",
          "legendFormat": "write {{device}}",
          "refId": "B"
        }
      ]
    }
  ]
}
